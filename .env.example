# CLAW X — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── REQUIRED ──────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here

# ── BINANCE (optional — dry run by default) ───
BINANCE_API_KEY=
BINANCE_SECRET=

# ── TELEGRAM NOTIFICATIONS (optional) ────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── WALLET TRACKER (optional) ─────────────────
ETHERSCAN_API_KEY=
ALCHEMY_API_KEY=

# ── OTHER (optional) ──────────────────────────
WHALE_ALERT_API_KEY=
CRYPTOPANIC_API_KEY=
NEWS_API_KEY=
